# Copy this file to .env.local and fill in the values.
# Run `cdk deploy` in the backend/ folder and use the stack outputs as values below.

# API Gateway HTTP API endpoint — output: RefugioMentalStack.ApiUrl
NEXT_PUBLIC_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com

# Cognito — outputs: RefugioMentalStack.UserPoolId / UserPoolClientId
NEXT_PUBLIC_COGNITO_USER_POOL_ID=<region>_<id>
NEXT_PUBLIC_COGNITO_CLIENT_ID=<client-id>
NEXT_PUBLIC_COGNITO_REGION=us-east-1