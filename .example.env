# Copy this file to .env.local and fill in the values.
# Run `npm run deploy` in the backend/ folder and use the `ApiUrl` output as the value below.

# API Gateway HTTP API endpoint — output of `cdk deploy` as ApiUrl
NEXT_PUBLIC_API_URL=https://<api-id>.execute-api.<region>.amazonaws.com
NEXT_PUBLIC_COGNITO_USER_POOL_ID
NEXT_PUBLIC_COGNITO_CLIENT_ID
NEXT_PUBLIC_COGNITO_REGION